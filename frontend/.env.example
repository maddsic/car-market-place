# car-management-v2 (JCC) API — copy to .env and adjust if needed
VITE_API_BASE_URL=http://localhost:3000
VITE_API_VERSION=/api/v1

# Must match JWT_SECRET in car-management-v2/.env (Remix server loaders verify authToken)
JWT_SECRET_KEY=your-jwt-secret-from-car-management-v2

